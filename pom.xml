<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.dpkflower</groupId>
    <artifactId>api</artifactId>
    <version>0.0.8.0</version>
    <name>api</name>
    <description>DPK Flower API</description>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.4</version>
        <relativePath/>
    </parent>
    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
        <java.version>21</java.version>
        <spring-cloud.version>2023.0.0</spring-cloud.version>
        <mapstruct.version>1.5.5.Final</mapstruct.version>
        <firebase.version>9.1.1</firebase.version>
        <sonar.coverage.exclusions>
            **/client/**,
            **/dto/**,
            **/mapper/**,
            **/entity/**,
            **/request/**,
            **/response/**,
            **/config/**,
            **/security/**,
            **/constant/**,
            **/queue/**,
            **/exception/**,
            **/repository/**,
            **/interceptor/**,
            **/service/ResponseTransformable.java,
            **/controller/GlobalExceptionHandlerController.java,
            **/Application.java,
            **/utils/BeanUtil.java
        </sonar.coverage.exclusions>
        <sonar.cpd.exclusions>
            **/dto/**,
            **/entity/**,
            **/request/**,
            **/response/**,
        </sonar.cpd.exclusions>
    </properties>
    <dependencies>
